# Copy to .env.local for local dev, or set these in Vercel → Project → Settings → Environment Variables.

# Single shared password that gates access to the app. Required in production.
APP_PASSWORD=change-me

# Redis connection string — stores the entire knowledge base as one JSON value.
# Connect a Redis database in Vercel (Storage tab) and it injects REDIS_URL
# automatically (a redis:// or rediss:// URL). For local dev you can pull it with
# `vercel env pull .env.development.local`. If unset, the app falls back to a
# local file (.data/store.json), which works for dev but does NOT persist on
# serverless hosting.
REDIS_URL=
