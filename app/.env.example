# Copy to .env.local for local dev, or set these in Vercel → Project → Settings → Environment Variables.

# Single shared password that gates access to the app. Required in production.
APP_PASSWORD=change-me

# Upstash Redis (serverless) — stores the entire knowledge base as one JSON blob.
# Get these from the Upstash integration in the Vercel Marketplace, or from the
# Upstash console. If unset, the app falls back to a local file (.data/store.json),
# which works for dev but does NOT persist on serverless hosting.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
